# API key required by all protected endpoints (X-API-Key header)
API_KEY=replace-with-a-strong-random-secret

# FMCSA API key for carrier lookup (SaferWatch / FMCSA web services)
FMCSA_API_KEY=replace-with-your-fmcsa-key

# SQLAlchemy database URL — defaults to a local SQLite file if unset
DATABASE_URL=sqlite:///./carrier_sales.db

# Secret used to sign JWT tokens (HS256)
JWT_SECRET=replace-with-a-strong-random-secret
